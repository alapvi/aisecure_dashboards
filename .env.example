# Copy this file to .env.local and adapt the values.
# Do not commit .env.local to GitHub.

export SO_ES_URL="https://ELASTICSEARCH_HOST:9200"
export SO_ES_INDEX="logs-*"
export SO_ES_USER="CHANGE_ME"
export SO_ES_PASS="CHANGE_ME"
export SO_VERIFY_TLS="false"

export SO_TIME_FROM="now-24h"
export SO_TIME_TO="now"
export SO_TIME_ZONE="Europe/Madrid"
export SO_HTML_REFRESH_SECONDS="600"
export SO_LOGO_FILE="/path/to/logo_institut.png"

# For the network traffic dashboard
# export SO_OUTPUT_HTML="/var/www/html/dashboard_so.html"

# For the security overview dashboard
# export SO_OUTPUT_HTML="/var/www/html/security_overview.html"
